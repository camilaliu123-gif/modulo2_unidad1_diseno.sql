CREATE TABLE Clientes(
 -- Número entero para identificar cada producto
id_Cliente int not null identity(1,1) Primary key,
-- Texto de hasta 100 caracteres para describir el nombre
nombre varchar (100),
-- Texto que no tiene max de caracteres. 
perfil_bio VARCHAR(MAX),
-- Date es usado para fecha de registro y que indique en formato de fecha
fecha_registro DATE
);

CREATE TABLE Productos(
 -- Número entero para identificar cada producto
id_producto INT NOT NULL identity (1,1) Primary Key,
-- Texto de hasta 255 caracteres para describir el producto
descripcion varchar(255),
 -- Precio con dos decimales para evitar errores de precisión
precio decimal(10,2),
 -- TRUE si el producto está activo y FALSE si no lo está
esta_activo BIT
);

